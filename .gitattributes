# Normalize all text files to LF in the repo, regardless of contributor OS.
* text=auto eol=lf

# Treat binary assets as binary: no EOL conversion, no textual diff/merge.
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.zip  binary

# SVG is XML text; keep it diffable but LF-normalized.
*.svg  text eol=lf
